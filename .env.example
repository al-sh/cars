# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Пароль к PostgreSQL
# Используется в backend и в postgres-контейнере
DB_PASSWORD=your_secure_password_here

# Секрет для подписи JWT-токенов.
# Минимум 32 символа. Сгенерировать: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters

# API-ключ DeepSeek.
# Получить на: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here
